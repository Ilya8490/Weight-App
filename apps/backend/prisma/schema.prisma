generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String        @id @default(cuid())
  email     String        @unique
  password  String
  createdAt DateTime      @default(now())
  entries   MetricEntry[]
}

model MetricEntry {
  id            String   @id @default(cuid())
  userId        String
  weight        Float
  height        Float
  age           Int
  gender        String
  activityLevel String
  bmi           Float
  idealWeight   Float
  bmr           Float
  calories      Float
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}
